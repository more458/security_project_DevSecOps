#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE — Config (no secretos)
#--------------------------------------------------------------------
database.default.hostname = db
database.default.DBDriver = MySQLi
database.default.port     = 3306

#--------------------------------------------------------------------
# DATABASE — Secretos (completar en .env local o inyectar desde Secrets Manager)
#--------------------------------------------------------------------
database.default.database = CHANGEME_DB_NAME
database.default.username = CHANGEME_DB_USER
database.default.password = CHANGEME_DB_PASSWORD

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# Generar con: php spark key:generate
encryption.key = CHANGEME_ENCRYPTION_KEY